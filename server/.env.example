# ── Server .env ────────────────────────────────────────────────────────────────
# Copy to .env and fill in your values. Never commit the real .env.

# Port — macOS reserves 5000 for AirPlay; use 5001.
PORT=5001

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/swms-dev

# JWT signing secret — use a long random string in production
JWT_SECRET=change-me-use-a-long-random-secret

# CORS origin — the Vite dev server URL (or production domain)
CLIENT_ORIGIN=http://localhost:5173

# Owner seed account — must match mock data userId so Phase 3 unification is seamless
OWNER_USER_ID=udit.sharma
OWNER_PASSWORD=change-me-must-be-strong
OWNER_NAME=Udit Sharma
